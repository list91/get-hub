# Cloudflare Worker build cache
.wrangler/
node_modules/

# Local secrets — never commit
php/config.php
.dev.vars
.env

# get-hub — the KV store holds the live door-key (bridge-...) and module secrets. NEVER commit.
# (I5) The product now lives at the repo ROOT, so store + host .env are ignored at root.
# Covers the default store file, any *.json store, and the host .env — but NOT the
# placeholder .env.example, test fixtures, or the SPEC.
/.env
get-hub-store.json
*-store.json
*.store.json
get-hub-store.*.json
!.env.example
# guard against a test/temp store written beside modules or in test/ dirs
**/.*-store.json
**/*-test-store.json
