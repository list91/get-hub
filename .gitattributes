# Normalize all text to LF on checkout, on every platform.
# Without this, a Windows clone (core.autocrlf=true) ships CRLF, which breaks
# the shell scripts (`env: 'bash\r'`) and the .env parsing (`BIND=127.0.0.1\r`).
* text=auto eol=lf

# Executables / shell / node / env must always be LF.
*.sh   text eol=lf
*.mjs  text eol=lf
*.js   text eol=lf
*.php  text eol=lf
*.py   text eol=lf
*.env  text eol=lf
.env.example text eol=lf
*.service text eol=lf
*.pem  text eol=lf

# Binaries (none yet, but keep git from mangling them if added).
*.png binary
*.jpg binary
*.ico binary
