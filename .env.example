# get-hub — configuration. Copy to .env, `chmod 600 .env`, keep OUT of git.
# PLACEHOLDER values only — the host .env is the ONLY place a real secret ever lives (I5).
# Never commit a real token/key/PEM.
#
# server.mjs loads THIS file itself, for EVERY entrypoint (the HTTP server AND the
# `issue`/`kill`/`show` operator CLI), via a built-in tolerant parser. So the systemd unit
# needs NO EnvironmentFile, and you do NOT source this file before the CLI.
#
# Parser rules (keep values simple, one comment per line ABOVE its key):
#   - full-line `#` comments and blank lines are ignored;
#   - `KEY=value` per line; write values BARE (no wrapping quotes needed);
#   - a multi-word value (e.g. ALLOW_HOSTS) may be left unquoted — the whole line value is taken;
#   - an unquoted trailing ` # comment` is stripped;
#   - a value wrapped in matching "..." or '...' is kept literal (quotes removed, no inner strip);
#   - a REAL environment variable (or systemd-set var) always WINS over this file.
#
# Every value is read by kernel.mjs loadConfig (globals) or by a module's frozen <NAME>_
# namespace view. Modules never read process.env.
#
# Generic convention: ANY `<VAR>_FILE=/path` (with <VAR> itself unset) is expanded by the
# kernel at boot to the file's contents — used below for GITHUB_APP_PEM_FILE.

# ── network ─────────────────────────────────────────────────────────────────
# TCP port. Default 8787. If you co-host multiple gateways on ONE host, give each a
# UNIQUE port — a bridge-mta-style service may already own 8787.
PORT=8787
# Bind address. Set to the host's LAN IP for LAN access; NEVER 0.0.0.0. Default 127.0.0.1.
BIND=127.0.0.1

# Proxy host allowlist for core.proxy — space or comma separated, UNQUOTED (the loader takes
# the whole line value). Enforced post-normalization (I8); core.proxy refuses every host not listed.
# Default: api.github.com api.telegram.org
ALLOW_HOSTS=api.github.com api.telegram.org

# ── store + key/auth lifecycle ──────────────────────────────────────────────
# JSON store (door-key + module secrets), written 0600. Default ./get-hub-store.json next to kernel.mjs.
STORE_PATH=./get-hub-store.json
# TTL applied to the door-key / minted secrets on issue. Default 3600.
KEY_TTL_SEC=3600
# Allowed clock skew / replay window for a SIGNED url, ± seconds. Default 120 (TIGHT).
# SECURITY-RELEVANT under public exposure: a captured signed URL is replayable at most this
# long (and only until its nonce is seen). Keep small when internet-facing; raise only for
# badly clock-skewed clients. (Was 3600 — a 1-hour public replay window.)
TS_WINDOW_SEC=120
# How long a used nonce is remembered (in-memory anti-replay). Default = TS_WINDOW_SEC (120).
# No point retaining longer than the ts window — anything older is already ts_expired.
NONCE_TTL_SEC=120
# Max proxied response bytes before truncation. Default 100000.
DO_MAX_RESP=100000

# ── public-exposure / DoS hardening ──────────────────────────────────────────
# Read these before putting get-hub on the public internet (see DEPLOY.md "Public exposure").
# The kernel is single-threaded, has NO IP awareness and trusts NO client header — per-IP rate
# limiting can ONLY be done at a fronting reverse proxy. These knobs bound in-process blast radius.
# Allow the degraded ?key=<door-key> unsigned form. Default true (on) — it is the browser-LLM
# fetch-only data path. Set 0/false to REFUSE it (error key_param_disabled) so the raw secret
# never rides in a URL / proxy log; only do this if every client can HMAC-sign. Default true.
ALLOW_KEY_PARAM=true
# Hard cap on the in-memory nonce set (bounded ring — evicts oldest past the cap). Makes an
# authenticated-flood OOM impossible. Default 100000.
NONCE_MAX=100000
# HTTP server limits (node:http) — bound slow/half-open/flooding connections so an anonymous
# attacker with NO door-key can't stall the single event loop. All ms unless noted.
# Time to receive all request headers, ms. Default 8000.
HTTP_HEADERS_TIMEOUT_MS=8000
# Time to receive the full request, ms. Default 15000.
HTTP_REQUEST_TIMEOUT_MS=15000
# Keep-alive idle timeout, ms. Default 5000.
HTTP_KEEPALIVE_TIMEOUT_MS=5000
# Max simultaneous TCP connections. Default 256.
HTTP_MAX_CONNECTIONS=256
# Per-socket inactivity timeout before destroy, ms. Default 20000.
HTTP_SOCKET_TIMEOUT_MS=20000
# Max request-URL length; an over-long URL gets 414 before it reaches the kernel. Default 2048.
HTTP_MAX_URL_LEN=2048

# ── outbound proxy tuning (core.proxy) ──────────────────────────────────────
# Per-hop outbound HTTPS timeout, ms. Default 10000.
PROXY_TIMEOUT_MS=10000
# Max SAME-host redirects followed (cross-host never). Default 3.
PROXY_MAX_REDIRECT=3
# Outbound User-Agent header. Default get-hub/1.0.
UA=get-hub/1.0

# ── operator identity for the control plane (I12) — KERNEL-owned, NOT module policy ──
# Only needed if you use the Telegram operator `/issue` trigger. The kernel binds operator
# identity to the SENDER (from.id), not the shared chat-id, so an ordinary member of a
# whitelisted GROUP can never trigger rotate. Space or comma separated.
# user-ids authorized to operate from ANY chat (REQUIRED for groups). Default empty.
OPERATOR_SENDERS=
# chat-ids trusted as 1:1 operator DMs (authorize only when sender == chat). Default empty.
OPERATOR_CHATS=
# legacy alias for OPERATOR_CHATS (still read by the kernel). Default empty.
TELEGRAM_WHITELIST=

# ── exec primitive (RCE surface) — OFF by default (I7) ──────────────────────
# Needed by the `run` and `temp` modules. Set EXEC_ENABLED=1 AND point EXEC_DIR at a dir
# of vetted, argument-free scripts to enable core.exec. Leaving it off => run/temp return
# {ok:false,error:"exec_disabled"}.
# 1 or "true" enables core.exec. Default 0 (disabled).
EXEC_ENABLED=0
# Dir of vetted scripts. REQUIRED when exec is on. Under systemd this MUST be an ABSOLUTE path
# (e.g. /home/<user>/get-hub/scripts) — a relative ./scripts resolves against the unit's
# WorkingDirectory and is fragile. Default empty.
EXEC_DIR=
# exec wall-clock timeout, ms, then SIGKILL. Default 10000.
EXEC_TIMEOUT_MS=10000
# max captured stdout bytes. Default 65536.
EXEC_MAX_OUT=65536
# max argv length (run/temp pass 0 args anyway). Default 16.
EXEC_MAX_ARGS=16
# max length of a single argv token. Default 4096.
EXEC_MAX_ARG_LEN=4096

# ── github module (namespace GITHUB_*) — pure secret injection, no per-service policy ──
# Two ways to provision the token the github module injects as `Authorization: Bearer`:
#   Mode 2 (simplest): a static token in GITHUB_TOKEN.
#   Mode 1 (auto-rotating ~1h): GitHub App creds (APP_ID + INSTALL_ID + a PEM). `issue github`
#     mints a fresh installation token via rotate; App creds take precedence over GITHUB_TOKEN.
# Scope the token AT GITHUB (read-only / specific repos) — the bridge adds no repo/mode policy.
# static token (github_pat_… / ghp_… / installation token). Default empty.
GITHUB_TOKEN=
# GitHub App id (Mode 1). Default empty.
GITHUB_APP_ID=
# GitHub App installation id (Mode 1). Default empty.
GITHUB_INSTALL_ID=
# App private key, INLINE — paste the full PKCS#8/PKCS#1 PEM (real newlines, or "\n"-escaped
# single line). Modules cannot read files (node:fs is a kernel-only clamp, I3). Default empty.
GITHUB_APP_PEM=
# App private key via FILE — point at the PEM file; the kernel reads it at boot into
# GITHUB_APP_PEM (generic *_FILE convention). Convert an App key to PKCS#8 first if needed:
#   openssl pkcs8 -topk8 -nocrypt -in app.pem -out app.pkcs8.pem
# Default empty.
GITHUB_APP_PEM_FILE=

# ── telegram module (namespace TELEGRAM_*) — background long-poll + operator /issue rotate ──
# OPTIONAL and OFF when empty. The long-poll daemon is fire-and-forget: an empty token means
# the daemon no-ops, and a present token can never block the HTTP listener from binding.
# bot token (<digits>:<base64url>). Default empty.
TELEGRAM_TOKEN=
