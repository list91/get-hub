# ─────────────────────────────────────────────────────────────────────────
# bridge-mta — secrets & config manifest
#
# The Worker reads these as Cloudflare Worker SECRETS, NOT from this file.
# This file only documents what to set. For each one run:
#     wrangler secret put <NAME>
# and paste the value when prompted. Never commit real values.
# ─────────────────────────────────────────────────────────────────────────

# --- Telegram keychain bot (required for the ⚡/💀 key-rotation bot) ---

# Bot token from @BotFather (format: "123456789:AA...").
TG_TOKEN=

# A random secret you choose. Used TWICE:
#   1. as the webhook URL path:  https://<worker>/tg/<TG_WEBHOOK_SECRET>
#   2. as the setWebhook secret_token header (X-Telegram-Bot-Api-Secret-Token).
# Generate: `openssl rand -hex 16`
TG_WEBHOOK_SECRET=

# Space/comma-separated numeric Telegram user ids allowed to use the bot.
# Find yours by messaging @userinfobot. Empty = allow everyone (NOT recommended).
TG_OWNER_IDS=

# --- GitHub App (OPTIONAL — only if you use the api.github.com token injection) ---

# GitHub App id (Settings → Developer settings → GitHub Apps → your app).
GITHUB_APP_ID=

# Installation id. After installing the App on your account/org, the URL is
# github.com/settings/installations/<INSTALL_ID>.
GITHUB_INSTALL_ID=

# The App private key, in PKCS#8 PEM. GitHub gives you PKCS#1 — CONVERT it first:
#   openssl pkcs8 -topk8 -nocrypt -in app.pkcs1.pem -out app.pkcs8.pem
# Then: `wrangler secret put GITHUB_APP_PEM < app.pkcs8.pem`
GITHUB_APP_PEM=

# --- Bridge proxy config (optional; has safe defaults in code) ---

# Comma/space-separated hostnames op=do is allowed to reach (SSRF allowlist).
# Default in code: api.github.com api.telegram.org
# THIS is the main knob to point the bridge at your own APIs.
ALLOW_HOSTS=api.github.com api.telegram.org

# --- KV namespace (set in wrangler.toml, NOT here) ---
# Create: `wrangler kv namespace create NONCES` → paste id into wrangler.toml.

# ─────────────────────────────────────────────────────────────────────────
# PHP port (php/bridge.php) — copy php/config.example.php → php/config.php
#   ACCESS_KEY : a random static key clients pass as key=... (token mode)
#   GH_TOKEN   : optional fallback GitHub token; usually passed per-request via gh=
# ─────────────────────────────────────────────────────────────────────────
