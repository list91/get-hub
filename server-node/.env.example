# bridge-mta-node — copy to .env, fill in, then: set -a; . ./.env; set +a
# Server
PORT=8787
BIND=127.0.0.1
STORE_PATH=./bridge-store.json
ALLOW_HOSTS="api.github.com api.telegram.org"
KEY_TTL_SEC=3600
TS_WINDOW_SEC=3600

# GitHub token injection for op=do → api.github.com (optional). Two ways:
#
# (A) Static token — simplest. A Personal Access Token / fine-grained token.
#     The bridge injects it as `Authorization: Bearer`. No App, no JWT needed.
#     Use a LEAST-PRIVILEGE token (fine-grained, read-only, only the repos you
#     expose) — whoever holds the bridge key can act as this token.
GITHUB_TOKEN=
#
#     Rights are governed by the token itself. Optionally clamp them at the bridge:
#       GITHUB_MODE=readonly   -> refuse POST/PUT/PATCH/DELETE to GitHub (default: readwrite)
#       GITHUB_REPOS="owner/repo owner/other"  -> only allow /repos/<those> (default: any the token allows)
GITHUB_MODE=readwrite
GITHUB_REPOS=
#
# (B) GitHub App — mints short-lived (~1h) installation tokens on demand via
#     `node server.mjs issue`. Convert the App private key to PKCS#8 once:
#       openssl pkcs8 -topk8 -nocrypt -in app.pem -out app.pkcs8.pem
#     A minted App token takes precedence over GITHUB_TOKEN when present.
GITHUB_APP_ID=
GITHUB_INSTALL_ID=
GITHUB_APP_PEM_PATH=
